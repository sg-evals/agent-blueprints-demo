# Agent Blueprints Demo — Token Configuration
#
# Copy this file to demo/.env and fill in your values.
# setup.sh and run_demo.sh will source this file automatically if present.
#
# DO NOT commit demo/.env — it contains secrets.

# Anthropic API key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Sourcegraph access token
# Get yours at: https://sourcegraph.com/user/settings/tokens
# Scopes needed: read (no special scopes required for public repos)
SOURCEGRAPH_ACCESS_TOKEN="sgp_..."

# GitHub personal access token
# Get yours at: https://github.com/settings/tokens (classic) or fine-grained tokens
# Scopes needed:
#   repo          — push trigger branches, post commit comments
#   workflow      — register self-hosted runner, trigger workflows
GITHUB_TOKEN="ghp_..."
